# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/schoolbox_scraper

# API authentication
SCRAPER_API_KEY=your-api-key-here

# Schoolbox credentials (stored only on VPS, never in client)
SCHOOLBOX_URL=https://mytyndale.tyndale.edu.au/
SCHOOLBOX_USERNAME=your-email@example.com
SCHOOLBOX_PASSWORD=your-password

# Schoolbox student/parent IDs
SCHOOLBOX_STUDENT_ID=8087
SCHOOLBOX_PARENT_ID=8166

# Server
PORT=3000

# Data directory for downloaded files
DATA_DIR=/data
